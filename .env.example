# Copy this file to apps/web/.env — paths below are relative to apps/web/:
#   cp .env.example apps/web/.env

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...

# Database (SQLite; resolved relative to apps/web/prisma/)
DATABASE_URL="file:../../data/dev.db"

# Vault — markdown notes directory (resolved from apps/web/ at runtime)
VAULT_DIR=../../vault

# Engine safety caps
MAX_DELEGATION_DEPTH=3
GLOBAL_RUN_TIMEOUT_MS=600000
MAX_LOOP_ITERATIONS=20

# Optional providers
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434
